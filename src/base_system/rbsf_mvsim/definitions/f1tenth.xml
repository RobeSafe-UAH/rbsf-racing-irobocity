<vehicle:class name="f1tenth-car">
    <dynamics class="ackermann">
        <rl_wheel pos="0 0.148" mass="0.2" width="0.045" diameter="0.109" />
        <rr_wheel pos="0 -0.148" mass="0.2" width="0.045" diameter="0.109" />
        
        <fl_wheel mass="0.2" width="0.045" diameter="0.109" />
        <fr_wheel mass="0.2" width="0.045" diameter="0.109" />
        
        <f_wheels_x>0.324</f_wheels_x>
        <f_wheels_d>0.296</f_wheels_d>
        
        <max_steer_ang_deg>30.0</max_steer_ang_deg>

        <chassis mass="4.0" zmin="0.03" zmax="0.25">
            <shape>
                <pt> 0.45  0.15</pt>
                <pt> 0.45 -0.15</pt>
                <pt>-0.15 -0.15</pt>
                <pt>-0.15  0.15</pt>
            </shape>
        </chassis>

        <controller class="twist_front_steer_pid">
            <KP>15.0</KP>
            <KI>2.0</KI>
            <I_MAX>15.0</I_MAX>
            <KD>0.5</KD>
            <V>0.0</V>
            <W>0.0</W>
            <max_torque>25.0</max_torque>
        </controller>

        <drivetrain type="torsen_4wd">
            <front_rear_split>0.5</front_rear_split>
            <front_rear_bias>1.5</front_rear_bias>
            <front_left_right_split>0.5</front_left_right_split>
            <front_left_right_bias>1.5</front_left_right_bias>
            <rear_left_right_split>0.5</rear_left_right_split>
            <rear_left_right_bias>1.5</rear_left_right_bias>
        </drivetrain>
    </dynamics>

    <friction class="default">
        <mu>1.2</mu>
        <C_damping>0.002</C_damping>
    </friction>

    <if condition="${default_sensors|true}">
        <include file="../definitions/lidar2d.sensor.xml" 
            sensor_x="0.15" 
            sensor_z="0.20" 
            sensor_yaw="0" 
            max_range="10.0" 
            sensor_name="laser1"
        />
    </if>
</vehicle:class>